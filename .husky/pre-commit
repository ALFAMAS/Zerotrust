#!/usr/bin/env sh
echo "⚙️  Running pre-commit checks..."

# 1. Format + lint staged files with Biome
# bunx biome check --write --staged --no-errors-on-unmatched
# if [ $? -ne 0 ]; then
#   echo "❌ Biome check failed"
#   echo "Run 'bun run lint:fix' to apply fixes, then re-stage and commit."
#   exit 1
# fi

# 2. Detect accidental secrets in staged files
echo "🔒 Scanning for secrets..."
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$STAGED" ]; then
  PRIVATE_KEY_RE="(pass[A-Za-z0-9 /+]{3}EGIN .* PRIVATE KEY-----)"
  SECRET_PATTERNS="$PRIVATE_KEY_RE"
  FOUND=$(git diff --cached | grep -iE "$SECRET_PATTERNS" | grep -v "example\|placeholder\|your-\|<\|_HEX=0\|process\.env\|\.env\." | head -5)
  if [ -n "$FOUND" ]; then
    echo "⚠️  Possible secrets detected in staged files. Review before committing:"
    echo "$FOUND"
    echo "If these are intentional placeholders, commit with --no-verify"
    exit 1
  fi
fi

# 3. Update dependency graph (graphify) if installed
if command -v graphify >/dev/null 2>&1; then
  echo "📊 Updating dependency graph..."
  graphify update . --silent 2>/dev/null || true
  git add graphify-out/ 2>/dev/null || true
fi

echo "✅ Pre-commit checks passed"