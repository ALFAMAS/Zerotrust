# 2. Detect accidental secrets in staged files
echo "🔒 Scanning for secrets..."
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$STAGED" ]; then
  PRIVATE_KEY_RE="(pass[A-Za-z0-9 /+]{3}EGIN .* PRIVATE KEY-----)"
  SECRET_PATTERNS="$PRIVATE_KEY_RE"
  FOUND=$(git diff --cached | grep -iE "$SECRET_PATTERNS" | grep -v "example\|placeholder\|your-\|<\|_HEX=0\|process\.env\|\.env\." | head -5)
  if [ -n "$FOUND" ]; then
    echo "⚠️  Possible secrets detected in staged files. Review before committing:"
    echo "$FOUND"
    echo "If these are intentional placeholders, commit with --no-verify"
    exit 1
  fi
fi

# 4. Block unapproved destructive migration DDL (P3.5)
echo "🗄️  Checking migration DDL safety..."
bun run migrations:check
if [ $? -ne 0 ]; then
  echo "❌ Destructive migration gate failed"
  exit 1
fi

echo "✅ Pre-commit checks passed"