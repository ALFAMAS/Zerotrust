#!/usr/bin/env sh
echo "⚙️  Running pre-commit checks..."

# 1. Format + lint staged files
cd "$(git rev-parse --show-toplevel)" && bunx lint-staged
if [ $? -ne 0 ]; then
  echo "❌ lint-staged failed"
  exit 1
fi

# 2. TypeScript type check (API)
echo "🔍 Type checking..."
bun run type-check
if [ $? -ne 0 ]; then
  echo "❌ TypeScript type check failed"
  exit 1
fi

# 3. Detect accidental secrets in staged files
echo "🔒 Scanning for secrets..."
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$STAGED" ]; then
  SECRET_PATTERNS='(password\s*=\s*["\x27][^"\x27]{8,}|api[_-]?key\s*=\s*["\x27][A-Za-z0-9]{16,}|secret\s*=\s*["\x27][^"\x27]{8,}|sk-[A-Za-z0-9]{20,}|AIza[0-9A-Za-z\-_]{35}|-----BEGIN .* PRIVATE KEY-----)'
  FOUND=$(git diff --cached | grep -iE "$SECRET_PATTERNS" | grep -v "example\|placeholder\|your-\|<\|_HEX=0\|process\.env\|\.env\." | head -5)
  if [ -n "$FOUND" ]; then
    echo "⚠️  Possible secrets detected in staged files. Review before committing:"
    echo "$FOUND"
    echo "If these are intentional placeholders, commit with --no-verify"
    exit 1
  fi
fi

# 4. Update dependency graph (graphify) if installed
if command -v graphify >/dev/null 2>&1; then
  echo "📊 Updating dependency graph..."
  graphify update . --silent 2>/dev/null || true
  # Stage any updated graph files
  git add graphify-out/ 2>/dev/null || true
fi

echo "✅ Pre-commit checks passed"
