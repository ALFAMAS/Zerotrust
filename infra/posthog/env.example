# PostHog hobby deploy environment (generated by scripts/ops/posthog-hobby.sh)
#
# PostHog maintains its own compose project under infra/posthog/ after the first
# run of the official deploy-hobby installer. These variables are documented here
# for operators who manage the stack manually.
#
# Minimum recommended host: 4 vCPU, 16 GB RAM, 30+ GB disk.
# Official docs: https://posthog.com/docs/self-host

# Public URL users and browsers reach (no trailing slash)
# POSTHOG_DOMAIN=localhost
# SITE_URL=http://localhost

# Generated by deploy-hobby — do not commit real values
# POSTHOG_SECRET=
# ENCRYPTION_SALT_KEYS=

# Image tags (defaults from upstream hobby compose)
# REGISTRY_URL=posthog/posthog
# POSTHOG_APP_TAG=latest
# POSTHOG_NODE_TAG=latest

# zerotrust UI integration (packages/ui/.env.local)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=http://localhost
