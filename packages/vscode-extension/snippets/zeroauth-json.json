{
  "ZeroAuth Client Init": {
    "prefix": "za-client",
    "body": [
      "import { ZeroAuthClient } from \"@zeroauth/sdk\";",
      "",
      "const auth = new ZeroAuthClient({",
      "  baseUrl: \"${1:https://auth.example.com}\",",
      "  tokenStorage: \"${2|localStorage,memory,cookie|}\"",
      "});"
    ],
    "description": "Initialize ZeroAuthClient"
  },
  "ZeroAuth Attestation Policy": {
    "prefix": "za-policy",
    "body": [
      "{",
      "  \"level\": \"${1|none,indirect,direct|}\",",
      "  \"allowSelfAttestation\": ${2:false},",
      "  \"requireFidoCertified\": ${3:true},",
      "  \"allowedAAGUIDs\": [${4}],",
      "  \"deniedAAGUIDs\": []",
      "}"
    ],
    "description": "ZeroAuth attestation policy object"
  },
  "ZeroAuth Tenant Config": {
    "prefix": "za-tenant",
    "body": [
      "{",
      "  \"slug\": \"${1:acme}\",",
      "  \"name\": \"${2:Acme Corp}\",",
      "  \"plan\": \"${3|free,starter,pro,enterprise|}\",",
      "  \"settings\": {",
      "    \"mfaRequired\": ${4:true},",
      "    \"enforceSSO\": ${5:false},",
      "    \"sessionTTL\": ${6:28800}",
      "  }",
      "}"
    ],
    "description": "ZeroAuth tenant configuration object"
  }
}
