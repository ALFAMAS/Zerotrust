{
  "name": "@zerotrust/ui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "partytown:copy": "partytown copylib public/~partytown",
    "react-scan:copy": "node scripts/react-scan-assets.mjs copy",
    "react-scan:clean": "node scripts/react-scan-assets.mjs clean",
    "predev": "bun run partytown:copy && bun run react-scan:copy",
    "dev": "next dev -p 3000",
    "prebuild": "bun run partytown:copy && bun run react-scan:clean",
    "build": "next build",
    "start": "next start -p 3000",
    "analyze": "next experimental-analyze",
    "analyze:output": "next experimental-analyze --output",
    "size": "size-limit",
    "size:build": "bun run build && bun run size",
    "pretest": "bun run partytown:copy",
    "lint": "biome check ../..",
    "lint:fix": "biome check --write ../..",
    "format": "biome format --write ../..",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
