# ============================================================
# ZeroAuth UI — Environment Variables
# Copy this file to .env.local and fill in your values.
# All NEXT_PUBLIC_* variables are inlined at build time and
# exposed to the browser. Never put secrets here.
# ============================================================


# ------------------------------------------------------------
# App Identity
# ------------------------------------------------------------

# The short name of your app — shown in the nav, logo, and titles.
NEXT_PUBLIC_APP_NAME=ZeroAuth

# One-line marketing tagline used in meta tags and SEO.
NEXT_PUBLIC_APP_TAGLINE=Zero Trust Authentication for Modern Apps

# Longer description used in <meta name="description"> and OpenGraph.
NEXT_PUBLIC_APP_DESCRIPTION=Enterprise-grade authentication for modern applications. PASETO tokens, WebAuthn passkeys, MFA, RBAC, and more.

# Single letter (or short string) rendered inside the logo square.
NEXT_PUBLIC_LOGO_LETTER=Z

# Background colour of the logo square (any valid CSS colour).
NEXT_PUBLIC_LOGO_COLOR=#6366f1

# Primary brand / accent colour (used for buttons, highlights).
NEXT_PUBLIC_BRAND_COLOR=#6366f1

# Licence shown in the footer (e.g. MIT, Apache-2.0).
NEXT_PUBLIC_LICENSE=MIT

# Year shown in the copyright notice. Defaults to the current year.
# NEXT_PUBLIC_COPYRIGHT_YEAR=2026


# ------------------------------------------------------------
# Hero / Landing Page Content
# ------------------------------------------------------------

# Small badge text shown above the hero heading.
NEXT_PUBLIC_ANNOUNCEMENT=Now with OIDC provider + SAML 2.0

# First line of the hero H1.
NEXT_PUBLIC_HERO_TITLE=Zero Trust Authentication

# Second (gradient) line of the hero H1.
NEXT_PUBLIC_HERO_SUBTITLE=for Modern Apps

# Paragraph below the hero heading.
NEXT_PUBLIC_HERO_DESCRIPTION=Enterprise-grade auth without the enterprise complexity. PASETO tokens, WebAuthn passkeys, multi-factor auth, RBAC/ABAC, and real-time anomaly detection — all in one self-hosted platform.


# ------------------------------------------------------------
# Legal
# ------------------------------------------------------------

# Short company name used throughout legal pages.
NEXT_PUBLIC_COMPANY_NAME=ZeroAuth

# Full legal entity name.
NEXT_PUBLIC_COMPANY_LEGAL_NAME=ZeroAuth, Inc.

# Mailing address (optional — leave blank to omit from pages).
# NEXT_PUBLIC_COMPANY_ADDRESS=123 Main St, Springfield, USA

# Email shown on the Privacy Policy page.
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@example.com

# Effective date of the current Privacy Policy.
NEXT_PUBLIC_PRIVACY_DATE=January 1, 2026

# Effective date of the current Terms of Service.
NEXT_PUBLIC_TERMS_DATE=January 1, 2026

# Governing-law jurisdiction string used in Terms of Service.
NEXT_PUBLIC_JURISDICTION=the laws of the United States

# How many days user data is retained (shown in Privacy Policy).
NEXT_PUBLIC_DATA_RETENTION_DAYS=90

# Cookie domain used in the cookie table on the Privacy Policy page.
NEXT_PUBLIC_COOKIE_DOMAIN=localhost


# ------------------------------------------------------------
# Links
# ------------------------------------------------------------

# Canonical URL of the frontend app.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# GitHub repository URL (used in footer and CTA).
NEXT_PUBLIC_GITHUB_URL=https://github.com/ALFAMAS/zeroauth

# General support / contact email address.
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com


# ------------------------------------------------------------
# API
# ------------------------------------------------------------

# Base URL of the ZeroAuth backend API (no trailing slash).
NEXT_PUBLIC_ZEROAUTH_URL=http://localhost:3000


# ------------------------------------------------------------
# Analytics  (only injected after cookie consent is accepted)
# ------------------------------------------------------------

# Plausible Analytics domain (e.g. yourdomain.com). Leave blank to disable.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=


# ------------------------------------------------------------
# Error Monitoring (Sentry)
# ------------------------------------------------------------

# Client-side Sentry DSN. Set to enable browser error capture and session replay.
# NEXT_PUBLIC_SENTRY_DSN=

# Server-side Sentry DSN (may be the same as the client DSN).
# Used in Next.js server components and API routes.
# SENTRY_DSN=

# Optional: Sentry auth token for source-map upload during builds.
# SENTRY_AUTH_TOKEN=
