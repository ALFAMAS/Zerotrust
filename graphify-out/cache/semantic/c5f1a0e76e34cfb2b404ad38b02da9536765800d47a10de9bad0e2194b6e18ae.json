{"nodes": [{"id": "roadmap_did_admin", "label": "Decentralized Identity (DID) Admin Tool", "file_type": "document", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": "2026-06-15", "author": null, "contributor": null, "rationale": "DID resolver code (resolveDID/resolveDIDWeb/resolveDIDKey, base58 codec) was already built but had no UI; exposing a /admin/did resolve + proof-of-control challenge tool is the cheapest, highest-impact way to surface a shipped-but-undocumented subsystem."}, {"id": "roadmap_jit_crosstenant", "label": "Cross-Tenant JIT Access", "file_type": "document", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": "2026-06-15", "author": null, "contributor": null, "rationale": "requestCrossTenantAccess()/CrossTenantJITStore existed with no UI; a requester page (/dashboard/jit) plus an admin approval inbox (/admin/jit) turns auto-expiring (<=1h) grants into a usable, auditable workflow."}, {"id": "roadmap_workload_identity", "label": "Workload / Agent Identity", "file_type": "document", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": "2026-06-15", "author": null, "contributor": null, "rationale": "The 2026 frontier for an auth platform is agentic auth; issuing short-lived, narrowly-scoped client-credential tokens that carry a principal_type:agent + workload_id claim lets AI agents and services be distinguished from human users on top of the existing OIDC + token-exchange foundation."}, {"id": "roadmap_federation_token_exchange", "label": "Identity Federation (RFC 8693 Token Exchange)", "file_type": "document", "source_file": "ROADMAP.md", "source_location": null, "source_url": null, "captured_at": "2026-06-15", "author": null, "contributor": null, "rationale": "exchangeToken()/initFederationFromEnv()/listProviders() existed but were undocumented; a trusted-provider registry UI at /admin/federation surfaces the RFC 8693 token-exchange back