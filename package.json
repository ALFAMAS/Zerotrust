{
  "name": "zeroauth",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "dev": "bunx concurrently --kill-others-on-fail -n API,UI -c cyan,magenta \"bun --watch src/api/server.ts\" \"bun run --cwd packages/ui dev\"",
    "dev:api": "bun --watch src/api/server.ts",
    "dev:ui": "bun run --cwd packages/ui dev",
    "build": "node ./node_modules/typescript/lib/tsc.js",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "db:backup": "node scripts/db-backup.js",
    "start": "node dist/api/server.js",
    "test": "bunx vitest",
    "test:watch": "bunx vitest --watch",
    "test:coverage": "bunx vitest --coverage",
    "lint": "bunx eslint src --ext .ts",
    "lint:fix": "bunx eslint src --ext .ts --fix",
    "format": "bunx prettier --write \"src/**/*.ts\"",
    "type-check": "node ./node_modules/typescript/lib/tsc.js --noEmit",
    "prepare": "bunx husky",
    "lint-staged": "bunx lint-staged",
    "release": "bunx semantic-release",
    "release:dry": "bunx semantic-release --dry-run"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "bunx prettier --write"
    ],
    "src/**/!(*.test|*.spec).ts": [
      "bunx eslint --fix --max-warnings=0"
    ],
    "packages/ui/src/**/*.{ts,tsx}": [
      "bunx prettier --write"
    ],
    "*.{json,md}": [
      "bunx prettier --write"
    ]
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@sentry/node": "^10.56.0",
    "@simplewebauthn/server": "^13.3.1",
    "@simplewebauthn/types": "^12.0.0",
    "@swc/core-win32-x64-msvc": "^1.15.40",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "geoip-lite": "^2.0.2",
    "hono": "^4.12.23",
    "ioredis": "^5.11.1",
    "nanoid": "^5.1.11",
    "nodemailer": "^8.0.10",
    "otpauth": "^9.5.1",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "samlify": "^2.13.1",
    "stripe": "^22.2.0",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^6.0.2",
    "ua-parser-js": "^2.0.10",
    "xpath": "^0.0.34",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@rollup/rollup-linux-x64-gnu": "^4.61.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.9.2",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/ua-parser-js": "^0.7.39",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "4.1.8",
    "concurrently": "^10.0.3",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.55.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0",
    "vitest": "4.1.8"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "optionalDependencies": {
    "@parcel/watcher-darwin-arm64": "2.5.6",
    "@parcel/watcher-darwin-x64": "2.5.6",
    "@parcel/watcher-linux-x64-glibc": "2.5.6",
    "@swc/core-linux-x64-gnu": "1.15.40",
    "@next/swc-win32-x64-msvc": "^16.2.7",
    "@next/swc-wasm-nodejs": "^16.2.7",
    "@next/swc-wasm-web": "^16.2.4",
    "@parcel/watcher-win32-x64": "^2.5.6",
    "@swc/core-win32-x64-msvc": "^1.15.40",
    "@rolldown/binding-darwin-arm64": "1.1.0",
    "@rolldown/binding-darwin-x64": "1.1.0",
    "@rolldown/binding-linux-x64-gnu": "1.1.0",
    "@rolldown/binding-win32-x64-msvc": "1.1.0",
    "@swc/core-darwin-arm64": "1.15.40",
    "@swc/core-darwin-x64": "1.15.40"
  }
}
