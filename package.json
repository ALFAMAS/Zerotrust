{
  "name": "@zeroauth/core",
  "version": "1.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "moduleResolution": "nodenext",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev:backend": "tsx watch src/server.ts",
    "dev:ui": "bun --cwd packages/ui run dev",
    "dev:admin": "bun --cwd packages/admin-ui run dev",
    "dev": "concurrently --names \"API,UI,ADMIN\" --prefix-colors \"cyan.bold,green.bold,yellow.bold\" --kill-others-on-fail \"bun run dev:backend\" \"bun run dev:ui\" \"bun run dev:admin\"",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@simplewebauthn/server": "^10.0.0",
    "@simplewebauthn/types": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "geoip-lite": "^1.4.10",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "mongoose": "^8.3.0",
    "nanoid": "^5.0.7",
    "nodemailer": "^6.9.13",
    "otpauth": "^9.3.0",
    "qrcode": "^1.5.3",
    "samlify": "^2.8.10",
    "swagger-ui-express": "^4.6.3",
    "twilio": "^4.7.0",
    "ua-parser-js": "^1.0.37",
    "xmldom": "^0.6.0",
    "xpath": "^0.0.34",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@rollup/rollup-linux-x64-gnu": "^4.60.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^11.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/release-notes-generator": "^12.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/qrcode": "^1.5.5",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ua-parser-js": "^0.7.39",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "conventional-changelog-conventionalcommits": "^7.0.2",
    "eslint": "^8.55.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.1.0",
    "semantic-release": "^23.0.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.6.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
