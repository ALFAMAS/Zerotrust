{
  "name": "zeroauth",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["packages/ui"],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n API,UI -c cyan,magenta \"tsx watch src/api/server.ts\" \"cd packages/ui && next dev -p 3001\"",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:ui": "cd packages/ui && next dev -p 3001",
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "start": "node dist/api/server.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@simplewebauthn/server": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.32.0",
    "geoip-lite": "^1.4.10",
    "hono": "^4.4.0",
    "ioredis": "^5.3.2",
    "nanoid": "^5.0.7",
    "nodemailer": "^6.9.13",
    "otpauth": "^9.3.0",
    "postgres": "^3.4.4",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.3",
    "samlify": "^2.8.10",
    "twilio": "^4.7.0",
    "ua-parser-js": "^1.0.37",
    "xmldom": "^0.6.0",
    "xpath": "^0.0.34",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@rollup/rollup-linux-x64-gnu": "^4.60.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^11.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/release-notes-generator": "^12.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/qrcode": "^1.5.5",
    "@types/ua-parser-js": "^0.7.39",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "concurrently": "^8.2.0",
    "conventional-changelog-conventionalcommits": "^7.0.2",
    "drizzle-kit": "^0.23.0",
    "eslint": "^8.55.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.1.0",
    "semantic-release": "^23.0.0",
    "tsx": "^4.6.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
