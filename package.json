{
  "name": "zerotrust",
  "version": "1.9.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "dev": "bunx concurrently --kill-others-on-fail -n API,UI -c cyan,magenta \"bun --watch src/api/server.ts\" \"bun run --cwd packages/ui dev\"",
    "dev:api": "bun --watch src/api/server.ts",
    "dev:ui": "bun run --cwd packages/ui dev",
    "build": "node ./node_modules/typescript/lib/tsc.js",
    "sdk:generate": "tsx scripts/codegen/generate-sdk.ts",
    "sdk:build": "npm run sdk:generate && node ./node_modules/typescript/lib/tsc.js -p packages/client/tsconfig.json",
    "docs:api": "node scripts/codegen/generate-api-docs.mjs",
    "sdk:check": "bun run sdk:generate && git diff --exit-code -- packages/client/src/index.ts",
    "audit:integration": "node scripts/codegen/audit-api-ui-map.mjs",
    "verify:generated": "bun run sdk:generate && bun run docs:api && bun run audit:integration && git diff --exit-code -- packages/client/src/index.ts docs/api-reference.md docs/api-ui-integration-matrix.md",
    "ops:smoke": "node scripts/ops/ops-smoke.mjs",
    "ops:verify-alerting": "node scripts/ops/verify-alerting.mjs",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "db:backup": "node scripts/ops/db-backup.js",
    "db:restore": "node scripts/ops/db-restore.js",
    "db:baseline-push": "bun scripts/ops/db-baseline-push.ts",
    "bootstrap:admin": "bun scripts/ops/bootstrap-admin.ts",
    "audit:anchor": "bun scripts/ops/audit-anchor.ts",
    "audit:anchor-verify": "bun scripts/ops/audit-anchor-verify.ts",
    "start": "node dist/src/api/server.js",
    "test": "bunx vitest",
    "test:watch": "bunx vitest --watch",
    "test:coverage": "bunx vitest --coverage",
    "test:coverage:ui": "bun run --cwd packages/ui vitest run --coverage",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "lint:ci": "bun run scripts/ci/run-biome-ci.ts",
    "load:auth-cache": "k6 run tests/load/auth-cache.k6.js",
    "load:login": "k6 run tests/load/login.k6.js",
    "branch-protection:check": "bun scripts/ci/verify-branch-protection.ts",
    "deploy-env:check": "bun scripts/ci/verify-deploy-environments.ts",
    "boundaries:check": "bun run scripts/ci/check-boundaries.ts",
    "org-scoping:check": "bun run scripts/ci/check-org-scoping.ts",
    "migrations:check": "bun run scripts/ci/check-destructive-migrations.ts",
    "migrations:journal:check": "bun run scripts/ci/check-drizzle-journal.ts",
    "migrations:schema:check": "bun run scripts/ci/check-drizzle-schema-drift.ts",
    "knip": "knip --no-config-hints",
    "dead-code": "knip --no-config-hints",
    "type-check": "node ./node_modules/typescript/lib/tsc.js --noEmit",
    "prepare": "bunx husky",
    "lint-staged": "biome check --write --staged --no-errors-on-unmatched",
    "release": "bunx semantic-release",
    "release:dry": "bunx semantic-release --dry-run"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@zerotrust/shared-types": "workspace:*",
    "@elastic/elasticsearch": "^9.4.2",
    "@hono/node-server": "^2.0.6",
    "@hono/zod-validator": "^0.8.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@sentry/node": "^10.62.0",
    "@simplewebauthn/server": "^13.3.2",
    "@simplewebauthn/types": "^12.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "geoip-lite": "^2.0.3",
    "hono": "^4.12.27",
    "ioredis": "^5.11.1",
    "nanoid": "^6.0.0",
    "nodemailer": "^9.0.1",
    "otpauth": "^9.5.1",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "stripe": "^22.3.0",
    "ua-parser-js": "^2.0.10",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@biomejs/cli-darwin-arm64": "2.5.2",
    "@biomejs/cli-darwin-x64": "2.5.2",
    "@biomejs/cli-linux-arm64": "2.5.2",
    "@biomejs/cli-linux-x64": "2.5.2",
    "@biomejs/cli-win32-x64": "2.5.2",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@rollup/rollup-linux-x64-gnu": "^4.62.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/ua-parser-js": "^0.7.39",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "concurrently": "^10.0.3",
    "conventional-changelog-conventionalcommits": "^10.2.0",
    "drizzle-kit": "0.31.10",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "knip": "^6.24.0",
    "semantic-release": "^25.0.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "undici": "^7.28.0"
  },
  "optionalDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.848.0",
    "pkcs11js": "^2.1.0",
    "@parcel/watcher-darwin-arm64": "2.5.6",
    "@parcel/watcher-darwin-x64": "2.5.6",
    "@parcel/watcher-linux-x64-glibc": "2.5.6",
    "@swc/core-linux-x64-gnu": "1.15.43",
    "@next/swc-win32-x64-msvc": "16.2.10",
    "@next/swc-wasm-nodejs": "16.2.10",
    "@next/swc-wasm-web": "16.2.10",
    "@parcel/watcher-win32-x64": "^2.5.6",
    "@swc/core-win32-x64-msvc": "^1.15.43",
    "@rolldown/binding-darwin-arm64": "1.1.5",
    "@rolldown/binding-darwin-x64": "1.1.5",
    "@rolldown/binding-linux-x64-gnu": "1.1.5",
    "@rolldown/binding-win32-x64-msvc": "1.1.5",
    "@swc/core-darwin-arm64": "1.15.43",
    "@swc/core-darwin-x64": "1.15.43"
  }
}
