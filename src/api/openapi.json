{
    "openapi": "3.0.0",
    "info": {
        "title": "ZeroAuth API",
        "version": "1.0.0"
    },
    "components": {
        "securitySchemes": {
            "ApiKeyAuth": {
                "type": "apiKey",
                "in": "header",
                "name": "x-api-key"
            }
        }
    },
    "security": [
        {
            "ApiKeyAuth": []
        }
    ],
    "paths": {
        "/auth/register": {
            "post": {
                "summary": "Register a new user",
                "requestBody": {
                    "required": true
                },
                "responses": {
                    "201": {
                        "description": "Created"
                    }
                }
            }
        },
        "/auth/login": {
            "post": {
                "summary": "Login",
                "requestBody": {
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/auth/token/refresh": {
            "post": {
                "summary": "Refresh token",
                "requestBody": {
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/auth/oauth/state": {
            "post": {
                "summary": "Request an ephemeral OAuth state token (PKCE/state)",
                "responses": {
                    "200": {
                        "description": "state returned"
                    }
                }
            }
        },
        "/auth/oauth/{provider}/callback": {
            "get": {
                "summary": "OAuth callback endpoint (supports PKCE/state)",
                "parameters": [
                    {
                        "name": "provider",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "code",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "state",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "code_verifier",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Tokens"
                    },
                    "400": {
                        "description": "Bad request"
                    }
                }
            }
        },
        "/ssf/events": {
            "post": {
                "summary": "Security Signals Framework (SSF) events webhook",
                "description": "Receives Security Event Tokens (SET) and performs automated responses (revocations/alerts)",
                "parameters": [
                    {
                        "name": "x-ssf-signature",
                        "in": "header",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Handled"
                    },
                    "401": {
                        "description": "Invalid signature"
                    }
                }
            }
        }
    }
}