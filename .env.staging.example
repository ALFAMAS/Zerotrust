# ZeroAuth — Staging Environment
#
# Staging mirrors production config with isolated resources. Copy this file
# to .env.staging (or your deploy platform's env settings) and fill values.
# Everything not listed here inherits the same keys as .env.example —
# staging differs only in the values, never the shape, so config drift
# between staging and production is impossible to introduce silently.

NODE_ENV=production

# Isolated staging database + Redis (never point at production data)
DATABASE_URL=postgresql://zeroauth:CHANGE_ME@staging-db:5432/zeroauth_staging
REDIS_URI=redis://staging-redis:6379

# Staging hostnames
APP_URL=https://staging.yourapp.com
PORT=3000

# Separate secrets from production — rotate independently
# Generate: openssl rand -hex 32
TOKEN_SECRET_HEX=
CSFLE_MASTER_KEY_HEX=

# Stripe TEST mode keys (sk_test_... / whsec_...) — staging never charges
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRODUCT_PRO=
STRIPE_PRODUCT_ENTERPRISE=
TRIAL_DAYS=14

# Mail: use a sandbox (Mailtrap / MailHog) so staging never emails real users
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=staging@yourapp.com

# Mirror production toggles so behaviour matches
HIBP_CHECK_ENABLED=true
LOGIN_NOTIFICATION_ENABLED=true
RATE_LIMITING_ENABLED=true

# Backups: enabled but to a separate bucket
BACKUP_ENABLED=true
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
BACKUP_S3_BUCKET=

# Observability — point at the same collectors as production, tagged staging
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
ALERT_ERROR_THRESHOLD=20
