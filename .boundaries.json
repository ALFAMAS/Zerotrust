{
  "$schema": "./scripts/boundaries.schema.json",
  "version": 1,
  "domains": {
    "shared": {
      "paths": [
        "src/shared/",
        "src/config/",
        "src/logger/",
        "src/models/",
        "src/db/storageFallback.ts",
        "src/db/schema.ts",
        "src/audit/",
        "src/services/shared/",
        "src/middleware/cors.ts",
        "src/middleware/inputSanitization.ts",
        "src/middleware/rateLimiter/",
        "src/middleware/apiKeyAuth.ts",
        "src/middleware/requirePlan.ts",
        "src/middleware/requireAdmin.ts",
        "src/plugins/"
      ],
      "can_import": []
    },
    "integrations": {
      "paths": [
        "src/notifications/dispatcher.ts",
        "src/notifications/formatters.ts",
        "src/mfa/channels/",
        "src/templates/",
        "src/services/notifications/"
      ],
      "can_import": ["shared"]
    },
    "identity": {
      "paths": [
        "src/api/routes/auth.routes.ts",
        "src/api/routes/session.routes.ts",
        "src/api/routes/passkey.routes.ts",
        "src/api/routes/verification.routes.ts",
        "src/api/routes/api-keys.routes.ts",
        "src/services/auth/",
        "src/crypto/",
        "src/mfa/",
        "src/db/repositories/authSessions.repository.ts",
        "src/middleware/auth.ts",
        "src/middleware/deviceAttestation.ts",
        "src/middleware/continuousEval.ts"
      ],
      "can_import": ["shared", "integrations"]
    },
    "tenancy": {
      "paths": [
        "src/api/routes/org.routes.ts",
        "src/api/routes/tenant.routes.ts",
        "src/jit/"
      ],
      "can_import": ["shared", "integrations", "identity"]
    },
    "billing": {
      "paths": [
        "src/api/routes/billing.routes.ts",
        "src/api/routes/billing.webhooks.ts",
        "src/api/routes/wallet.routes.ts",
        "src/services/billing/",
        "src/db/repositories/stripeEvents.repository.ts",
        "src/db/repositories/processedWebhookEvents.repository.ts"
      ],
      "can_import": ["shared", "integrations", "identity", "tenancy"]
    },
    "compliance": {
      "paths": [
        "src/api/routes/compliance.routes.ts",
        "src/api/routes/access-review.routes.ts",
        "src/api/routes/unsubscribe.routes.ts",
        "src/api/routes/notification.routes.ts",
        "src/api/routes/region.routes.ts",
        "src/api/routes/globalization.routes.ts",
        "src/services/compliance/"
      ],
      "can_import": ["shared", "integrations", "identity", "tenancy", "billing", "ops"]
    },
    "ops": {
      "paths": [
        "src/api/routes/admin.routes.ts",
        "src/api/routes/admin-tools.routes.ts",
        "src/api/routes/search.routes.ts",
        "src/api/routes/feedback.routes.ts",
        "src/api/routes/support.routes.ts",
        "src/api/routes/anomaly.routes.ts",
        "src/api/routes/email-events.routes.ts",
        "src/services/ops/",
        "src/webhooks/",
        "src/ssf/",
        "src/metrics/",
        "src/telemetry/",
        "src/notifications/routes.ts"
      ],
      "can_import": ["shared", "integrations", "identity", "tenancy", "billing", "compliance"]
    },
    "plugins": {
      "paths": ["plugins/"],
      "can_import": ["shared", "integrations", "identity"]
    }
  }
}
